# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=price_pro_monthly
NEXT_PUBLIC_STRIPE_PRO_YEARLY_PRICE_ID=price_pro_yearly
NEXT_PUBLIC_STRIPE_TEAMS_MONTHLY_PRICE_ID=price_teams_monthly
NEXT_PUBLIC_STRIPE_TEAMS_YEARLY_PRICE_ID=price_teams_yearly

# OAuth (Supabase providers)
# Supabase provider slug for LinkedIn: linkedin_oidc (recommended) or linkedin
NEXT_PUBLIC_LINKEDIN_SUPABASE_PROVIDER=linkedin_oidc

# LinkedIn direct profile sync (/api/linkedin/start -> /api/linkedin callback)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
# Optional override. If not set, defaults to {NEXT_PUBLIC_APP_URL}/api/linkedin
LINKEDIN_REDIRECT_URI=https://your-domain.com/api/linkedin

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
